# Document Processing Pipeline — Environment Variables
# Copy this file to .env and fill in your keys.

# ── Required ────────────────────────────────────────────────────────────────
# OpenRouter API key (for text extraction via Qwen)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google AI API key (for vision/OCR via Gemini)
GOOGLE_API_KEY=your_google_ai_api_key_here

# ── Optional overrides (defaults shown) ─────────────────────────────────────
# Vision model: PDF page images → Markdown (Google Gemini)
VISION_MODEL=gemini-3-flash-preview

# Text model: Markdown → structured JSON (OpenRouter)
TEXT_MODEL=qwen/qwen3.6-plus:free

# Max tokens for Gemini vision responses (generous — covers 18-page transcripts)
VISION_MAX_TOKENS=65536

# Max tokens for Qwen text responses
TEXT_MAX_TOKENS=32768

# PDF render DPI (150 = sharp enough for OCR, reasonable payload size)
PDF_DPI=150

# HTTP timeout for all LLM calls in seconds
HTTP_TIMEOUT=300.0

# Retry settings
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2.0

# Enable debug logging
DEBUG=false
